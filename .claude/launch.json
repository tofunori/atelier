{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "notes-editor",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "cd notes-src && npx vite --port \"${PORT:-5173}\""
      ],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "whiteboard-editor",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "cd whiteboard-src && npx vite --port \"${PORT:-5174}\""
      ],
      "port": 5174,
      "autoPort": true
    },
    {
      "name": "muxy-extension-panel",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "cd cmux-gallery && npx vite --port \"${PORT:-5175}\""
      ],
      "port": 5175,
      "autoPort": true
    },
    {
      "name": "figures-gallery",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "export CLAUDE_PREVIEW=1; export PORT=\"${PORT:-9359}\"; if [ -d \"$PWD/assets\" ]; then export ATELIER_ASSETS_DIR=\"$PWD/assets\"; elif [ -d \"$HOME/.local/share/atelier/assets\" ]; then export ATELIER_ASSETS_DIR=\"$HOME/.local/share/atelier/assets\"; fi; exec atelier serve --root \"$PWD\" --port \"$PORT\""
      ],
      "port": 9359,
      "autoPort": true
    }
  ]
}
